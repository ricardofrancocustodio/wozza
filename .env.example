PORT=4000

# NeonDB — copie a connection string do dashboard do Neon (Settings > Connection string)
DATABASE_URL=

# Meta (Instagram + Facebook via Facebook Page)
# App ID: 962011780083673
# Crie em https://developers.facebook.com → Meu Aplicativo → Configurações → Básico
META_APP_ID=962011780083673
META_APP_SECRET=
# Opcional: sobrescreve os scopes Meta. Se vazio, usa o conjunto business moderno do backend.
# Default: instagram_basic,instagram_manage_comments,pages_show_list,business_management
META_SCOPES=

# Instagram Direct Login (sem precisar de Facebook Page)
# Crie um app Instagram em https://developers.facebook.com
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# URL base do servidor (sem barra final) — usada no redirect_uri do OAuth
APP_URL=http://localhost:4000

# Upload opcional de imagens para postagem social.
# Em produção na Vercel, crie um Blob Store e copie o token Read/Write.
BLOB_READ_WRITE_TOKEN=

# Chave forte usada para criptografar tokens OAuth de canais sociais no banco.
# Gere uma chave longa e exclusiva por ambiente. Exemplo PowerShell:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
ENCRYPTION_KEY=

# Autenticação do painel Wozza
# Opcional: envia links de primeira senha/redefinição por Resend.
RESEND_API_KEY=
AUTH_EMAIL_FROM=Wozza <no-reply@wozza.app>

# Login social do painel Wozza
# Redirect URIs:
# - http://localhost:4000/auth/google/callback
# - http://localhost:4000/auth/facebook/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# TikTok for Business
# Crie em https://ads.tiktok.com/marketing_api/docs
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# LinkedIn
# Crie em https://www.linkedin.com/developers/apps → Create App
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
