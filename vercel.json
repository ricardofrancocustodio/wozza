{
  "version": 2,
  "crons": [
    {
      "path": "/api/internal/run-scheduler",
      "schedule": "* * * * *"
    }
  ],
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "*.html"]
      }
    }
  ],
  "routes": [
    { "src": "/privacy-policy\\.html", "status": 301, "headers": { "Location": "/privacy-policy" } },
    { "src": "/terms-of-service\\.html", "status": 301, "headers": { "Location": "/terms-of-service" } },
    { "src": "/privacy-portal\\.html", "status": 301, "headers": { "Location": "/portal-privacidade" } },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
